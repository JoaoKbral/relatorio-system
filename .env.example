# Cole aqui a URL do banco de dados do Neon
DATABASE_URL="DBURL"

# Segredo para assinar os tokens de sessão (gere com: openssl rand -base64 32)
SESSION_SECRET=change-this-to-a-random-32-char-secret

# Credenciais de acesso ao sistema
AUTH_EMAIL="EMAIL"
AUTH_PASSWORD="SENHA"

# Dados da igreja (usados no relatório ODT)
CHURCH_CITY_NEIGHBORHOOD= "CIDADE - BAIRRO"
CHURCH_CNPJ="CNPJ"
CHURCH_PASTOR="NOME TITULAR"
CHURCH_PRONTUARIO="PRONTUARIO TITULAR"
